# Enterprise AI Video Production Platform - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application
# =============================================================================
APP_NAME=Enterprise AI Video Production Platform
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# =============================================================================
# Database - PostgreSQL
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=avp
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=avp_platform

# =============================================================================
# Database - Neo4j
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# =============================================================================
# Database - Milvus
# =============================================================================
MILVUS_HOST=localhost
MILVUS_PORT=19530

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_base64_32
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENCRYPTION_KEY=your_encryption_key_here_32_bytes

# =============================================================================
# Storage
# =============================================================================
STORAGE_BACKEND=local
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE=524288000
MAX_VIDEO_DURATION=300

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# =============================================================================
# Video Generation
# =============================================================================
VIDEO_DEFAULT_RESOLUTION=1920x1080
VIDEO_MAX_RESOLUTION=3840x2160
VIDEO_DEFAULT_FPS=24
GPU_POOL_SIZE=4
MAX_CONCURRENT_GENERATIONS=10
GENERATION_TIMEOUT_SECONDS=600

# =============================================================================
# AI Models
# =============================================================================
DEFAULT_VIDEO_MODEL=stable-video-diffusion
DEFAULT_LLM_MODEL=gpt-4
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# Monitoring
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO

# =============================================================================
# Content Safety
# =============================================================================
CONTENT_SAFETY_ENABLED=true
AZURE_CONTENT_SAFETY_KEY=
AZURE_CONTENT_SAFETY_ENDPOINT=

# =============================================================================
# Watermark
# =============================================================================
WATERMARK_ENABLED=true
WATERMARK_C2PA_ENABLED=true
